/**
 * Lambda@Edge function for CloudFront request processing
 * 
 * Architecture: CloudFront -> Lambda@Edge -> S3
 * - Runs at CloudFront edge locations globally for low latency
 * - Intercepts viewer requests before cache lookup or S3 origin access
 * - Provides basic authentication and dynamic directory listing for S3 reports bucket
 * - For directory requests (/), generates HTML index of S3 bucket contents
 * - For file requests, passes through to S3 origin via CloudFront OAC
 * 
 * Template variables (substituted by Terraform):
 * - AUTH_PASSWORD: Basic auth password from Terraform variable
 * - BUCKET_NAME: S3 reports bucket name
 * - BUCKET_REGION: AWS region where S3 bucket is located
 */

// Use AWS SDK v3 for Node.js 18.x runtime
const { S3Client, ListObjectsV2Command } = require('@aws-sdk/client-s3');
const s3Client = new S3Client({ region: '${BUCKET_REGION}' });

exports.handler = async (event) => {
  const request = event.Records[0].cf.request;
  const headers = request.headers;
  const uri = request.uri;
  
  const authUser = 'viewer';
  const authPass = '${AUTH_PASSWORD}';
  
  const authString = 'Basic ' + Buffer.from(authUser + ':' + authPass).toString('base64');
  
  if (typeof headers.authorization == 'undefined' || headers.authorization[0].value != authString) {
    const body = 'Unauthorized';
    const response = {
      status: '401',
      statusDescription: 'Unauthorized',
      body: body,
      headers: {
        'www-authenticate': [{key: 'WWW-Authenticate', value:'Basic'}]
      }
    };
    return response;
  }
  
  // Handle directory listing requests
  if (uri === '/' || uri.endsWith('/')) {
    try {
      const bucketName = '${BUCKET_NAME}';
      const prefix = uri === '/' ? '' : uri.slice(1); // Remove leading slash
      
      // Parse pagination parameters from query string
      const url = new URL(`https://example.com$${request.uri}$${request.querystring ? '?' + request.querystring : ''}`);
      const page = parseInt(url.searchParams.get('page') || '1');
      const pageSize = 50;
      
      // Use S3 native pagination instead of loading everything into memory
      const params = {
        Bucket: bucketName,
        Prefix: prefix,
        Delimiter: '/',
        MaxKeys: pageSize
      };
      
      // For pages beyond the first, we need to paginate through S3
      let continuationToken = null;
      let currentPage = 1;
      
      // Navigate to the requested page using S3 pagination
      while (currentPage < page) {
        const tempParams = { ...params };
        if (continuationToken) {
          tempParams.ContinuationToken = continuationToken;
        }
        
        const tempCommand = new ListObjectsV2Command(tempParams);
        const tempData = await s3Client.send(tempCommand);
        
        if (!tempData.NextContinuationToken) {
          // No more pages available
          break;
        }
        
        continuationToken = tempData.NextContinuationToken;
        currentPage++;
      }
      
      // Now fetch the actual page we want
      if (continuationToken && currentPage === page) {
        params.ContinuationToken = continuationToken;
      }
      
      const command = new ListObjectsV2Command(params);
      const data = await s3Client.send(command);
      
      // Build HTML structure using array parts for better performance
      const htmlParts = [
        '<!DOCTYPE html>',
        '<html>',
        '<head>',
        '<title>Reports Index</title>',
        '<style>',
        'body { font-family: Arial, sans-serif; margin: 40px; }',
        'h1 { color: #333; }',
        '.directory { color: #0066cc; text-decoration: none; display: block; padding: 5px 0; }',
        '.directory:hover { text-decoration: underline; }',
        '.file { color: #666; }',
        'ul { list-style-type: none; padding-left: 0; }',
        'li { margin: 5px 0; }',
        '</style>',
        '</head>',
        '<body>',
        '<h1>Deposit Withdraw Monitor: Test Reports Directory</h1>'
      ];
      
      if (prefix) {
        htmlParts.push(`<p>Current path: <span style="color: green;">/$${prefix}</span></p>`);
      }
      
      htmlParts.push('<ul>');
      
      // Add parent directory link if not at root
      if (prefix !== '') {
        const parentPath = prefix.split('/').slice(0, -2).join('/');
        const parentUrl = parentPath === '' ? '/' : `/$${parentPath}/`;
        htmlParts.push(`<li><a href="$${parentUrl}" class="directory">[BACK]</a></li>`);
      }
      
      // Process current page items directly without storing in memory
      let itemCount = 0;
      
      // Process subdirectories from current S3 page
      if (data.CommonPrefixes) {
        for (const item of data.CommonPrefixes) {
          const folderName = item.Prefix.replace(prefix, '').replace('/', '');
          
          // Check if this looks like a timestamp directory (contains date/time pattern)
          const timestampDirRegex = /^\d{4}-\d{2}-\d{2}_\d{2}-\d{2}-\d{2}$/;
          const isTimestampDir = timestampDirRegex.test(folderName);
          
          if (isTimestampDir) {
            // For timestamp directories, link directly to index.html
            htmlParts.push(`<li><a href="/$${item.Prefix}index.html" class="file">$${folderName}</a></li>`);
          } else {
            // For other directories, show as directory
            htmlParts.push(`<li><a href="/$${item.Prefix}" class="directory">$${folderName}/</a></li>`);
          }
          itemCount++;
        }
        
        // Clean up S3 response data
        data.CommonPrefixes = null;
        delete data.CommonPrefixes;
      }
      
      // Process files from current S3 page
      if (data.Contents) {
        for (const item of data.Contents) {
          if (item.Key.endsWith('index.html')) {
            const relativePath = item.Key.replace(prefix, '');
            const fileName = relativePath.split('/').pop();
            htmlParts.push(`<li><a href="/$${item.Key}" class="file">[FILE] $${fileName}</a></li>`);
            itemCount++;
          }
        }
        // Clean up S3 contents data
        data.Contents = null;
        delete data.Contents;
      }
      
      // Determine if pagination controls are needed
      const hasNextPage = data.NextContinuationToken;
      const hasPrevPage = page > 1;
      const showPagination = hasNextPage || hasPrevPage;
      
      // Add pagination info
      if (showPagination) {
        const startIndex = ((page - 1) * pageSize) + 1;
        const endIndex = startIndex + itemCount - 1;
        htmlParts.push(`<p><strong>Showing $${startIndex}-$${endIndex} items (Page $${page})</strong></p>`);
      }
      
      // Add pagination controls (simplified for S3 native pagination)
      if (showPagination) {
        htmlParts.push('</ul><div style="margin-top: 20px; text-align: center;">');
        
        const currentPath = request.uri;
        
        // Previous page
        if (hasPrevPage) {
          htmlParts.push(`<a href="$${currentPath}?page=$${page - 1}" style="margin: 0 10px; padding: 8px 12px; background-color: #007bff; color: white; text-decoration: none; border-radius: 4px;">Previous</a>`);
        } else {
          htmlParts.push(`<span style="margin: 0 10px; padding: 8px 12px; background-color: #ccc; color: #666; border-radius: 4px;">Previous</span>`);
        }
        
        // Current page indicator
        htmlParts.push(`<span style="margin: 0 10px; padding: 8px 12px; background-color: #28a745; color: white; border-radius: 4px; font-weight: bold;">$${page}</span>`);
        
        // Next page
        if (hasNextPage) {
          htmlParts.push(`<a href="$${currentPath}?page=$${page + 1}" style="margin: 0 10px; padding: 8px 12px; background-color: #007bff; color: white; text-decoration: none; border-radius: 4px;">Next</a>`);
        } else {
          htmlParts.push(`<span style="margin: 0 10px; padding: 8px 12px; background-color: #ccc; color: #666; border-radius: 4px;">Next</span>`);
        }
        
        htmlParts.push(`</div><ul style="list-style: none;">`); // Reopen ul for consistency
      }
      
      // Add closing HTML tags
      htmlParts.push('</ul>', '</body>', '</html>');
      
      // Join all HTML parts into final string
      const finalHtml = htmlParts.join('');
      
      const response = {
        status: '200',
        statusDescription: 'OK',
        headers: {
          'content-type': [{key: 'Content-Type', value: 'text/html'}],
          'cache-control': [{key: 'Cache-Control', value: 'max-age=300'}]
        },
        body: finalHtml
      };
      
      // Clean up temporary variables
      htmlParts.length = 0;
      
      return response;
      
    } catch (error) {
      console.log('S3 Error:', error);
      const response = {
        status: '500',
        statusDescription: 'Internal Server Error',
        body: `Error listing directory: $${error.message}`
      };
      return response;
    }
  }
  
  // For file requests, pass through to S3
  return request;
};